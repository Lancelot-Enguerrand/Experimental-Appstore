{
  "schemaVersion": 2,
  "services": [
    {
      "name": "foldergram",
      "image": "ghcr.io/foldergram/foldergram:1.0.3",
      "environment": [
        {
          "key": "NODE_ENV",
          "value": "production"
        },
        {
          "key": "DATA_ROOT",
          "value": "/app/data"
        },
        {
          "key": "GALLERY_ROOT",
          "value": "/app/data/gallery"
        },
        {
          "key": "DB_DIR",
          "value": "/app/data/db"
        },
        {
          "key": "THUMBNAILS_DIR",
          "value": "/app/data/thumbnails"
        },
        {
          "key": "PREVIEWS_DIR",
          "value": "/app/data/previews"
        }
      ],
      "volumes": [
        {
          "hostPath": "${FOLDERGRAM_GALLERY_ROOT_PATH}",
          "containerPath": "/app/data/gallery",
          "readOnly": "${FOLDERGRAM_GALLERY_ACCESS:-false}"
        },
        {
          "hostPath": "${APP_DATA_DIR}/data/db",
          "containerPath": "/app/data/db"
        },
        {
          "hostPath": "${APP_DATA_DIR}/data/thumbnails",
          "containerPath": "/app/data/thumbnails"
        },
        {
          "hostPath": "${APP_DATA_DIR}/data/previews",
          "containerPath": "/app/data/previews"
        }
      ]
    }
  ]
}