{
  "schemaVersion": 2,
  "services": [
    {
      "name": "open-notebook",
      "image": "lfnovo/open_notebook:v1-latest",
      "isMain": true,
      "internalPort": 8502,
      "environment": [
        {
          "key": "OPEN_NOTEBOOK_ENCRYPTION_KEY",
          "value": "${OPEN_NOTEBOOK_ENCRYPTION_KEY}"
        },
        {
          "key": "SURREAL_URL",
          "value": "ws://open-notebook-surreal-db:8000/rpc"
        },
        {
          "key": "SURREAL_USER",
          "value": "tipi"
        },
        {
          "key": "SURREAL_PASSWORD",
          "value": "${OPEN_NOTEBOOK_DB_PASSWORD}"
        },
        {
          "key": "SURREAL_NAMESPACE",
          "value": "open_notebook"
        },
        {
          "key": "SURREAL_DATABASE",
          "value": "open_notebook"
        }
      ],
      "volumes": [
        {
          "hostPath": "${APP_DATA_DIR}/data/notebook",
          "containerPath": "/app/data"
        }
      ],
      "dependsOn": [
        "open-notebook-db"
      ]
    },
    {
      "name": "open-notebook-surreal-db",
      "image": "surrealdb/surrealdb:v2",
      "command": "start --log info --user root --pass ${OPEN_NOTEBOOK_DB_PASSWORD} rocksdb:/mydata/mydatabase.db --init-file /init.surql",
      "volumes": [
        {
          "hostPath": "${APP_DATA_DIR}/data/db",
          "containerPath": "/mydata"
        },
        {
          "hostPath": "${APP_DATA_DIR}/init",
          "containerPath": "/init",
          "readOnly": true
        }
      ]
    }
  ]
}
